<!-- Hero Section -->
<section class="relative overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-b from-mystic-purple/5 via-transparent to-transparent"></div>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-32 relative">
    <div class="text-center max-w-3xl mx-auto">
      <h1 class="font-heading text-5xl md:text-7xl font-bold gradient-gold-text mb-6 leading-tight">
        A Public Library of Arcane Wisdom
      </h1>
      <p class="text-lg md:text-xl text-gray-400 mb-8 leading-relaxed">
        A curated collection of mystical ebooks spanning astrology, divination, herbalism, alchemy, and the hidden arts. Read instantly in your browser.
      </p>
      <div class="flex flex-wrap items-center justify-center gap-4">
        <%= link_to "Browse Catalog", ebooks_path, class: "btn-gold text-lg px-8 py-3" %>
        <%= link_to "Learn More", about_path, class: "btn-outline-gold text-lg px-8 py-3" %>
      </div>
    </div>
  </div>
</section>

<!-- From the Collection -->
<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
  <div class="flex items-end justify-between mb-10">
    <div>
      <h2 class="font-heading text-3xl md:text-4xl font-bold gradient-gold-text mb-2">From the Collection</h2>
      <p class="text-gray-500">Hand-picked selections for the discerning seeker</p>
    </div>
    <%= link_to "View all →", ebooks_path, class: "text-sm text-gold hover:text-gold/70 transition-colors hidden sm:block mb-1" %>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
    <% @featured_ebooks.first(4).each do |ebook| %>
      <div class="card-dark p-6 group flex flex-col gap-3">
        <div class="flex items-center justify-between">
          <% if ebook.category %>
            <%= link_to ebook.category.name, category_path(slug: ebook.category.slug), class: "text-xs text-mystic-purple-light hover:text-mystic-purple transition-colors uppercase tracking-wider font-medium" %>
          <% end %>
          <% if ebook.publication_year %>
            <span class="text-xs text-gray-600"><%= ebook.publication_year %></span>
          <% end %>
        </div>
        <%= link_to ebook_path(ebook) do %>
          <h3 class="font-heading text-xl font-semibold text-gray-100 group-hover:text-gold transition-colors leading-snug"><%= ebook.title %></h3>
        <% end %>
        <p class="text-sm text-gray-500 italic">by <%= ebook.author %></p>
        <% if ebook.description.present? %>
          <p class="text-sm text-gray-400 leading-relaxed line-clamp-3"><%= ebook.description %></p>
        <% end %>
        <div class="flex items-center justify-between pt-3 border-t border-gray-800/50 mt-auto">
          <span class="text-xs text-gray-600"><%= ebook.page_count %> pages</span>
          <%= link_to "Read Now →", ebook_path(ebook), class: "btn-gold text-xs !py-1.5 !px-3" %>
        </div>
      </div>
    <% end %>
  </div>

  <div class="text-center mt-10">
    <%= link_to "Browse Full Catalog", ebooks_path, class: "btn-outline-gold" %>
  </div>
</section>

<!-- Categories -->
<section class="bg-gray-900/30 border-y border-gray-800/30">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="text-center mb-12">
      <h2 class="font-heading text-3xl md:text-4xl font-bold gradient-gold-text mb-3">Paths of Knowledge</h2>
      <p class="text-gray-500">Explore our mystical categories</p>
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
      <% @categories.each do |category| %>
        <%= link_to category_path(slug: category.slug), class: "card-dark p-6 text-center group" do %>
          <div class="w-12 h-12 mx-auto mb-3 rounded-full bg-mystic-purple/10 border border-mystic-purple/30 flex items-center justify-center group-hover:bg-mystic-purple/20 transition-colors">
            <%= category_icon_svg(category.icon) %>
          </div>
          <h3 class="font-heading text-lg font-semibold text-gray-200 group-hover:text-gold transition-colors mb-1"><%= category.name %></h3>
          <p class="text-xs text-gray-500"><%= category.ebooks.count %> titles</p>
        <% end %>
      <% end %>
    </div>
  </div>
</section>

<!-- Features -->
<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
  <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
    <div class="text-center">
      <div class="w-14 h-14 mx-auto mb-4 rounded-full bg-gold/10 border border-gold/30 flex items-center justify-center">
        <svg class="w-7 h-7 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
      </div>
      <h3 class="font-heading text-xl font-semibold text-gray-200 mb-2">Instant Reading</h3>
      <p class="text-sm text-gray-500">Open any book and start reading immediately. No checkout, no friction.</p>
    </div>
    <div class="text-center">
      <div class="w-14 h-14 mx-auto mb-4 rounded-full bg-gold/10 border border-gold/30 flex items-center justify-center">
        <svg class="w-7 h-7 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
      </div>
      <h3 class="font-heading text-xl font-semibold text-gray-200 mb-2">Open Access</h3>
      <p class="text-sm text-gray-500">Every uploaded book is available to the public. Share the knowledge freely.</p>
    </div>
    <div class="text-center">
      <div class="w-14 h-14 mx-auto mb-4 rounded-full bg-gold/10 border border-gold/30 flex items-center justify-center">
        <svg class="w-7 h-7 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
      </div>
      <h3 class="font-heading text-xl font-semibold text-gray-200 mb-2">Reader Friendly</h3>
      <p class="text-sm text-gray-500">A calm, focused reading view that works on desktop and mobile.</p>
    </div>
  </div>
</section>
