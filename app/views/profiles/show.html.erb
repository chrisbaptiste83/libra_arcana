<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
  <!-- Header -->
  <div class="flex items-center gap-4 mb-10">
    <div class="w-16 h-16 rounded-full bg-mystic-purple/30 border-2 border-mystic-purple/50 flex items-center justify-center">
      <span class="text-2xl font-bold text-mystic-purple-light"><%= current_user.first_name.first.upcase %></span>
    </div>
    <div>
      <h1 class="font-heading text-3xl font-bold text-gray-100"><%= current_user.full_name %></h1>
      <p class="text-gray-500 text-sm mt-0.5"><%= current_user.email %></p>
    </div>
    <div class="ml-auto flex gap-3 text-center">
      <div class="card-dark px-5 py-3 !transform-none">
        <p class="text-2xl font-bold gradient-gold-text"><%= @favorites.count %></p>
        <p class="text-xs text-gray-500 uppercase tracking-wider">Favorites</p>
      </div>
      <div class="card-dark px-5 py-3 !transform-none">
        <p class="text-2xl font-bold text-mystic-purple-light"><%= @reading_list_items.count %></p>
        <p class="text-xs text-gray-500 uppercase tracking-wider">In Library</p>
      </div>
    </div>
  </div>

  <!-- Currently Reading -->
  <% if @currently_reading.any? %>
    <section class="mb-12">
      <h2 class="font-heading text-2xl font-bold gradient-gold-text mb-6 flex items-center gap-2">
        <svg class="w-6 h-6 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
        Currently Reading
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <% @currently_reading.each do |item| %>
          <%= render "reading_list_card", item: item %>
        <% end %>
      </div>
    </section>
  <% end %>

  <!-- Favorites -->
  <section class="mb-12">
    <h2 class="font-heading text-2xl font-bold text-gray-200 mb-6 flex items-center gap-2">
      <svg class="w-6 h-6 text-gold fill-current" viewBox="0 0 24 24"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
      Favorites
      <span class="text-lg text-gray-500 font-normal">(<%= @favorites.count %>)</span>
    </h2>
    <% if @favorites.any? %>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <% @favorites.each do |favorite| %>
          <%= render "shared/ebook_card", ebook: favorite.ebook %>
        <% end %>
      </div>
    <% else %>
      <div class="card-dark p-8 text-center !transform-none">
        <svg class="w-12 h-12 text-gray-700 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
        <p class="text-gray-500">No favorites yet.</p>
        <%= link_to "Browse the catalog", ebooks_path, class: "text-gold hover:text-gold-light text-sm mt-1 inline-block" %>
      </div>
    <% end %>
  </section>

  <!-- Want to Read -->
  <section class="mb-12">
    <h2 class="font-heading text-2xl font-bold text-gray-200 mb-6 flex items-center gap-2">
      <svg class="w-6 h-6 text-mystic-purple-light" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z"/></svg>
      Want to Read
      <span class="text-lg text-gray-500 font-normal">(<%= @want_to_read.count %>)</span>
    </h2>
    <% if @want_to_read.any? %>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <% @want_to_read.each do |item| %>
          <%= render "reading_list_card", item: item %>
        <% end %>
      </div>
    <% else %>
      <div class="card-dark p-8 text-center !transform-none">
        <p class="text-gray-500">Your reading queue is empty.</p>
        <%= link_to "Discover ebooks", ebooks_path, class: "text-gold hover:text-gold-light text-sm mt-1 inline-block" %>
      </div>
    <% end %>
  </section>

  <!-- Completed -->
  <% if @completed.any? %>
    <section class="mb-12">
      <h2 class="font-heading text-2xl font-bold text-gray-200 mb-6 flex items-center gap-2">
        <svg class="w-6 h-6 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        Completed
        <span class="text-lg text-gray-500 font-normal">(<%= @completed.count %>)</span>
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <% @completed.each do |item| %>
          <%= render "reading_list_card", item: item %>
        <% end %>
      </div>
    </section>
  <% end %>

  <!-- Account Settings link -->
  <div class="border-t border-gray-800/50 pt-8">
    <%= link_to edit_user_registration_path, class: "text-sm text-gray-500 hover:text-gray-300 transition-colors flex items-center gap-2" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
      Account Settings
    <% end %>
  </div>
</div>
