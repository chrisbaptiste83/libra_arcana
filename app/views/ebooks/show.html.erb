<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
  <!-- Breadcrumb -->
  <nav class="mb-8 text-sm">
    <%= link_to "Catalog", ebooks_path, class: "text-gray-500 hover:text-gold transition-colors" %>
    <span class="text-gray-700 mx-2">/</span>
    <% if @ebook.category %>
      <%= link_to @ebook.category.name, category_path(slug: @ebook.category.slug), class: "text-gray-500 hover:text-gold transition-colors" %>
      <span class="text-gray-700 mx-2">/</span>
    <% end %>
    <span class="text-gray-400"><%= truncate(@ebook.title, length: 40) %></span>
  </nav>

  <div>
    <!-- Details -->
    <div class="w-full">
      <% if @ebook.featured? %>
        <span class="badge-gold mb-3 inline-block">Featured</span>
      <% end %>

      <% if @ebook.category %>
        <%= link_to @ebook.category.name, category_path(slug: @ebook.category.slug), class: "badge-purple mb-3 inline-block" %>
      <% end %>

      <h1 class="font-heading text-3xl md:text-4xl font-bold text-gray-100 mb-2"><%= @ebook.title %></h1>
      <p class="text-lg text-gray-400 mb-6">by <%= @ebook.author %></p>

      <div class="flex flex-wrap items-center gap-4 mb-8">
        <% if @ebook.ebook_file.attached? %>
          <%= link_to "#reader", class: "btn-gold text-base px-8 py-3" do %>
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
            Read Online
          <% end %>
          <%= link_to "Open in New Tab", rails_blob_path(@ebook.ebook_file, disposition: "inline"), target: "_blank", rel: "noopener", class: "btn-outline-gold text-base px-6 py-3" %>
        <% else %>
          <span class="text-sm text-gray-500">The reading file hasn't been uploaded yet.</span>
        <% end %>
      </div>

      <!-- Description -->
      <div class="mb-8">
        <h3 class="font-heading text-xl font-semibold text-gray-200 mb-3">Description</h3>
        <% unless @ebook.description.to_s.start_with?("Imported from S3.") %>
          <p class="text-gray-400 leading-relaxed"><%= @ebook.description %></p>
        <% end %>
      </div>

      <!-- Details Grid -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <% if @ebook.page_count.present? %>
          <div class="card-dark p-4 text-center !transform-none">
            <p class="text-xs text-gray-500 uppercase tracking-wider mb-1">Pages</p>
            <p class="text-lg font-semibold text-gray-200"><%= @ebook.page_count %></p>
          </div>
        <% end %>
        <% if @ebook.language.present? %>
          <div class="card-dark p-4 text-center !transform-none">
            <p class="text-xs text-gray-500 uppercase tracking-wider mb-1">Language</p>
            <p class="text-lg font-semibold text-gray-200"><%= @ebook.language %></p>
          </div>
        <% end %>
        <% if @ebook.publication_year.present? %>
          <div class="card-dark p-4 text-center !transform-none">
            <p class="text-xs text-gray-500 uppercase tracking-wider mb-1">Year</p>
            <p class="text-lg font-semibold text-gray-200"><%= @ebook.publication_year %></p>
          </div>
        <% end %>
        <% if @ebook.isbn.present? %>
          <div class="card-dark p-4 text-center !transform-none">
            <p class="text-xs text-gray-500 uppercase tracking-wider mb-1">ISBN</p>
            <p class="text-sm font-semibold text-gray-200"><%= @ebook.isbn %></p>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <% if @ebook.ebook_file.attached? %>
    <section id="reader" class="mt-12">
      <div class="flex items-center justify-between mb-4">
        <h2 class="font-heading text-2xl font-bold text-gray-200">Reader</h2>
        <%= link_to "Open Fullscreen", rails_blob_path(@ebook.ebook_file, disposition: "inline"), target: "_blank", rel: "noopener", class: "text-sm text-gold hover:text-gold-light transition-colors" %>
      </div>
      <div class="card-dark overflow-hidden">
        <iframe
          title="<%= @ebook.title %> reader"
          src="<%= rails_blob_path(@ebook.ebook_file, disposition: "inline") %>"
          class="w-full h-[75vh] bg-gray-950"
          loading="lazy"
        ></iframe>
      </div>
    </section>
  <% end %>

  <!-- Related Ebooks -->
  <% if @related_ebooks.any? %>
    <section class="mt-16">
      <h2 class="font-heading text-2xl font-bold gradient-gold-text mb-6">Related Ebooks</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <% @related_ebooks.each do |ebook| %>
          <%= render "shared/ebook_card", ebook: ebook %>
        <% end %>
      </div>
    </section>
  <% end %>
</div>
