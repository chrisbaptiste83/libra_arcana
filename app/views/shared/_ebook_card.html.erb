<div class="card-dark overflow-hidden group" data-controller="fade-in">
  <div class="p-4">
    <div class="mb-1">
      <% if ebook.category %>
        <%= link_to ebook.category.name, category_path(slug: ebook.category.slug), class: "text-xs text-mystic-purple-light hover:text-mystic-purple transition-colors" %>
      <% end %>
    </div>
    <%= link_to ebook_path(ebook), class: "block group/title" do %>
      <h3 class="font-heading text-lg font-semibold text-gray-100 group-hover/title:text-gold transition-colors leading-tight mb-1"><%= ebook.title %></h3>
    <% end %>
    <p class="text-sm text-gray-500 mb-3"><%= ebook.author %></p>
    <div class="flex items-center justify-between">
      <span class="text-xs text-gray-500">
        <%= ebook.ebook_file.attached? ? "Ready to read" : "File coming soon" %>
      </span>
      <%= link_to "Read", ebook_path(ebook), class: "btn-gold text-xs !py-1.5 !px-3" %>
    </div>
  </div>
</div>
